4><p>\"The quality of the meat and the delivery boxes are great! They respond quickly and fast delivered my meat box during the sale season. Thanks!\"<\/p>","author":"Sohaib A.","author_info":"","show_star_rating":true,"star_rating":5}},"testimonial_GegP39":{"type":"testimonial","settings":{"testimonial":"<p>\"They delivered the wrong specs, but they were kind enough to replace it the next day. You can't receive a faulty meat box from MLS. Happy to have such quality in Oman.\"<\/p>","author":"Abdullah A.","author_info":"","show_star_rating":true,"star_rating":5}}},"block_order":["testimonial_6x8PQU","testimonial_UkDYTe","testimonial_mpJkbV","testimonial_Cj8e7a","testimonial_GegP39"],"custom_css":["div#template--23070801428796__testimonials_cWpbVw {background: #31302d; color: white;}","h4 {color: white !important;}","h2.h4.text-center.justify-center {color: white;}","@media (min-width: 601px) {h2.h4.text-center.justify-center {font-size: 53px; }}"],"settings":{"heading":"MLS is loved by over 50,000 customers","show_quotes":false,"testimonial_size":"h6","testimonial_font":"body","text_position":"justify-center","text_align":"text-center justify-center","nav_style":"slideshow_nav_dots","transition":"slide-fade","autoplay":true,"slider_pause":false,"autoplay_speed":5,"color_scheme":"1","star_color":"#a70a10","full_width":true}},"custom_liquid_djJzaA":{"type":"custom-liquid","custom_css":[".custom-section-liquid {padding: 0px;}"],"settings":{"custom_liquid":"<div class=\"marbling-score-section\">\n    <h2 class=\"heading\">Marbling Score: A Meat Quality Meter<\/h2>\n<div  style=\"justify-content: center;\n    display: flex;\">\n    <p class=\"sub-heading\" >Craving a melt-in-your-mouth steak? Look for the marbling score! This number (0-9+) reveals the amount of fat within, with higher scores indicating more marbling. More marbling translates to richer flavor, juicier texture, and an unforgettable steak experience.<\/p>\n<\/div>\n    <div class=\"score-range\">\n        <span data-target=\"4-5\">4-5<\/span>\n        <span data-target=\"6-7\">6-7<\/span>\n        <span data-target=\"8-9\">8-9<\/span>\n    <\/div>\n    <div class=\"score-categories\">\n        <div class=\"score-category\" id=\"category-4-5\">\n            <div class=\"image-container\">\n                <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0285\/3732\/3629\/files\/4-5.png?v=1721048117\" alt=\"4-5 Marbling Score\">\n            <\/div>\n            <div class=\"text-container\">\n                <h3>MLS AUS Wagyu Beef MB 4\/5 Perfect for Steak Beginners<\/h3>\n                <p>Treat yourself to a delightful introduction to premium steak with a 4-5 marble score. Rich flavor, melt-in-your-mouth tenderness. Perfect for steak beginners.<\/p>\n            <\/div>\n        <\/div>\n        <div class=\"score-category\" id=\"category-6-7\">\n            <div class=\"image-container\">\n                <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0285\/3732\/3629\/files\/6-7.png?v=1721048117\" alt=\"6-7 Marbling Score\">\n            <\/div>\n            <div class=\"text-container\">\n                <h3>MLS AUS Wagyu Beef MB 6\/7: Next-Level Steak Experience<\/h3>\n                <p>Indulge in intense flavor and luxurious marbling with our MB 6\/7 Wagyu beef. Perfect for those seeking an exceptional steak experience.<\/p>\n            <\/div>\n        <\/div>\n        <div class=\"score-category\" id=\"category-8-9\">\n            <div class=\"image-container\">\n                <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0285\/3732\/3629\/files\/8-9.png?v=1721048117\" alt=\"8-9 Marbling Score\">\n            <\/div>\n            <div class=\"text-container\">\n                <h3>MLS AUS Wagyu Beef MB 8\/9: Ultimate Steak Indulgence<\/h3>\n                <p>Savor the unforgettable taste and melt-in-your-mouth texture of our MB 8\/9 Wagyu beef. The ultimate steak experience for discerning palates.<\/p>\n            <\/div>\n        <\/div>\n    <\/div>\n    <a href=\"#shopify-section-template--23070801428796__featured_collection_N46KPR\" class=\"explore-collection-button\">Explore Collection<\/a>\n<\/div>\n\n<style>\n.marbling-score-section {\n    text-align: center;\n    background-color: #1E1D1A;\n    color: #ffffff;\n    padding: 40px 20px;\n}\n\n.marbling-score-section h2 {\n    font-size: 2.5em;\n    margin-bottom: 20px;\n    font-weight: bold;\n}\n\n.marbling-score-section p {\n    font-size: 1.2em;\n    margin-bottom: 40px;\n}\n\n.score-range {\n    display: flex;\n    justify-content: center;\n    margin-bottom: 40px;\n    position: relative;\n    width: 70%;\n    margin-left: auto;\n    margin-right: auto;\n}\n\n.score-range span {\n    font-weight: bold;\n    font-size: 2.5em; \/* Updated size *\/\n    padding: 0 20px;\n    position: relative;\n    cursor: pointer;\n    transition: color 0.3s ease, font-size 0.3s ease, font-weight 0.3s ease;\n    color: #4B4A48; \/* Default color *\/\n}\n\n.score-range span.active {\n    color: #ffffff; \/* Active color *\/\n    font-weight: bold;\n}\n\n.score-range span.active::after {\n    content: \"\";\n    height: 8px; \/* Updated underline height *\/\n    background-color: #ffffff; \/* White underline when active *\/\n    position: absolute;\n    width: 100%;\n    top: 100%; \/* Position the underline above the long line *\/\n    left: 0;\n    font-weight: bold;\n}\n\n.score-range::after {\n    content: \"\";\n    height: 2px;\n    background-color: #ffffff;\n    position: absolute;\n    width: 100%;\n    bottom: -6px; \/* Adjust as needed to position correctly *\/\n    left: 0;\n}\n\n.score-categories {\n    display: flex;\n    justify-content: space-around;\n    margin-bottom: 40px;\n}\n\n.score-category {\n    width: 30%;\n    background-color: #333333;\n    border-radius: 10px;\n    overflow: hidden;\n    position: relative;\n    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    transition: transform 0.3s ease, width 0.3s ease, background-color 0.3s ease;\n}\n\n.score-category.active {\n    transform: scale(1.1);\n}\n\n.image-container {\n    position: relative;\n    width: 100%;\n    padding-top: 80%; \/* 1:1 Aspect Ratio *\/\n    overflow: hidden;\n}\n\n.image-container img {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: contain;\n}\n\n.text-container {\n    padding: 20px 10%;\n    background-color: #333333;\n    color: #B1B1AF; \/* Default text color *\/\n    transition: color 0.3s ease;\n}\n\n.text-container h3 {\n    font-size: 1.2em;\n    margin-bottom: 10px;\n    color: #B1B1AF; \/* Default heading color *\/\n}\n\n.text-container p {\n    font-size: 0.8em;\n    margin: 0;\n}\n\n.score-category.active .text-container,\n.score-category.active .text-container h3,\n.score-category.active .text-container p {\n    color: #ffffff; \/* Active text and heading color *\/\n}\n\n.explore-collection-button {\n    display: inline-block;\n    background-color: #e60000;\n    color: #fff;\n    padding: 15px 30px;\n    text-decoration: none;\n    font-size: 1.2em;\n    border-radius: 5px;\n    margin-top: 20px;\n}\n\n.explore-collection-button:hover {\n    background-color: #cc0000;\n}\n.heading{\ncolor: #fff;\n font-size:60px !important;\n}\n.sub-heading{\nwidth:70%;\n font-size:24px !important;\n}\n\/* Media Query for screens less than 600px *\/\n@media (max-width: 600px) {\n    .score-categories {\n        display: block;\n    }\n\n    .score-category {\n        width: 80%;\n         margin: 0 auto 20px;\n        display: none;\n    }\n\n    .score-category.active {\n        display: block;\n    }\n.score-range span {\n    font-size: 18px;\n}\n.heading{\ncolor: #fff;\n font-size:32px !important;\n}\n.sub-heading{\nwidth:80% !important;\n font-size:12px !important;\n}\n.text-container h3 {\n    font-size: 18px !important;\n}\n.text-container p {\n    font-size: 12px !important;\n}\n}\n\n<\/style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n    const scoreRanges = document.querySelectorAll('.score-range span');\n    const categories = document.querySelectorAll('.score-category');\n\n    \/\/ Set the first span and category as active by default\n    scoreRanges[0].classList.add('active');\n    categories[0].classList.add('active');\n\n    scoreRanges.forEach(range => {\n        range.addEventListener('click', function() {\n            const target = this.getAttribute('data-target');\n            categories.forEach(category => {\n                category.classList.remove('active');\n            });\n            document.getElementById('category-' + target).classList.add('active');\n\n            scoreRanges.forEach(span => {\n                span.classList.remove('active');\n            });\n            this.classList.add('active');\n        });\n    });\n});\n\n<\/script>","section_height":"default","full_width":true,"dividers":"none","prevent_animation":false}},"ecom_aus_wagyu_beed_reels_section_eXLjnq":{"type":"ecom-aus-wagyu-beed-reels-section","settings":{}},"featured_collection_N46KPR":{"type":"featured-collection","custom_css":[".cc-featured-collection {background: #1e1d1a;}",".card__info-container.flex.flex-col.flex-auto.relative {background: #31302d;}",".card__info-inner.flex.flex-col.h-full.text-center.w-full {color: white;}",".custom-feature-collectioin {margin: 0px; padding: 30px 0px;}","h2.h4.mb-0.flex-auto.section__heading.text-center {color: white;}"],"settings":{"title":"MLS Australian Wagyu Beef MB 4\/5","heading_align":"text-center","show_view_all":false,"collection":"australian-wagyu-beef-mb-4-5","layout":"carousel","card_size_mobile":"small","card_size":"large","products_to_show":8,"color_scheme":"none","card_contain":true,"full_width":true}},"featured_collection_jNbPQ4":{"type":"featured-collection","custom_css":[".cc-featured-collection {background: #1e1d1a;}",".card__info-container.flex.flex-col.fl