6WFuK5RKAM","video_description":"","poster_image":"shopify:\/\/shop_images\/Screenshot_2023-11-09_012420.png","video_size":"md","video_autoplay":false,"text_align":"text-center","color_scheme":"default"}},"faq_AVx4wh":{"type":"faq","blocks":{"question_TT4MQX":{"type":"question","settings":{"icon":"none","heading":"What’s the MLS Partner Program?","text":"<p>MLS Partner Program allows you to recommend people to our website and receive credit for any product purchased by the referred visitors. You share our provided link with the visitors, and we pay you a 5% commission on every sale your referred visitors make with the shared link!<\/p>"}},"question_YXxYmK":{"type":"question","settings":{"icon":"none","heading":"Do I need to be an MLS customer to join?","text":"<p>We encourage you to become one, but it’s not necessary. <\/p>"}},"question_LncMz4":{"type":"question","settings":{"icon":"none","heading":"How to sign up?","text":"<p>To become an MLS Partner, you need to complete the sign-up form. Please provide as much information as you can so we can provide the best tools for your needs.<br\/>Once you submit the form, we will send you a confirmation email so you can start affiliating. <\/p>"}},"question_aFttJT":{"type":"question","settings":{"icon":"none","heading":"Is it free to join?","text":"<p>Yes, it is 100% free to join our MLS partner program.<\/p>"}},"question_FmejR7":{"type":"question","settings":{"icon":"none","heading":"Are there any program limitations?","text":"<p>There are no limitations on the program; you can earn as much as you refer. <\/p>"}},"question_tWPan3":{"type":"question","settings":{"icon":"none","heading":"How many times can I get a commission on referring?","text":"<p>You will earn a 5% commission for every customer you refer who purchases through your affiliate link. The more you refer, the more you earn. <\/p>"}},"question_f7VnKr":{"type":"question","settings":{"icon":"none","heading":"How will I get paid?","text":"<p>You'll get paid at the end of the month. Your referral amount will be manually transferred to you on the provided bank. <\/p>"}},"question_kqwNQV":{"type":"question","settings":{"icon":"none","heading":"What are the customer service hours?","text":"<p>Our team will be there to assist you between 9 am - 6 pm Saturday - Thursday. <\/p>"}},"question_8jxr8E":{"type":"question","settings":{"icon":"none","heading":"How long does it take for the affiliate sale to be approved and visible in the dashboard?","text":"<p>It can take up to 2-3 days maximum.<\/p>"}},"question_wqaBQ7":{"type":"question","settings":{"icon":"none","heading":"Who should I contact for payment queries?","text":"<p>Kindly email us at <a href=\"mailto:contactus@mls.om\"><span style=\"text-decoration:underline\"><strong>contactus@mls.om<\/strong><\/span><\/a>with your queries.<\/p>"}}},"block_order":["question_TT4MQX","question_YXxYmK","question_LncMz4","question_aFttJT","question_FmejR7","question_tWPan3","question_f7VnKr","question_kqwNQV","question_8jxr8E","question_wqaBQ7"],"settings":{"heading":"FAQs","heading_align":"text-center","color_scheme":"none","full_width":true}}},"order":["main","slideshow_ghAzMw","rich_text_AcinEg","icons_with_text_UyGKqM","rich_text_4TmkrA","multi_column_LX74gC","multi_column_zX4nVG","icons_with_text_FAxT4t","video_PmrbgA","faq_AVx4wh"]}