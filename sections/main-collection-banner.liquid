    }
  ]
}
{% endschema %}


<style>
.collection-description.expanded {
  display: block;
  -webkit-line-clamp: unset;
  max-height: none;
}

  .collection-description {
  display: -webkit-box;
  -webkit-line-clamp: 3; /* Number of lines to display */
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
 
}
.read-more-button {
    margin-top: 10px;
    text-decoration: underline;
    color: #a70a10;
    font-weight: 600;
    text-underline-offset: .2rem;
}
  h1.collection-banner__heading.mb-0.inline.h2 {
    color: #a70a10;
    text-decoration: underline;
}
@media(max-width:600px){
    .collection-description {
    max-height: calc(1.27em * 3) ; /* Assuming line height is 1.2em and showing 3 lines */
    }
}
 @media(min-width:601px){
  .collection-description {
    max-height: calc(1.2em * 3) ; /* Assuming line height is 1.2em and showing 3 lines */
    }
}
  
</style>

<script>
  // Inject translations directly from Shopify locale files
  window.themeTranslations = {
    readMore: {{ 'sections.collection.read_more' | t | json }},
    readLess: {{ 'sections.collection.read_less' | t | json }}
  };
</script>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const readMoreButtons = document.querySelectorAll(".read-more-button");

  readMoreButtons.forEach(button => {
    button.addEventListener("click", function() {
      const description = this.previousElementSibling;
      description.classList.toggle("expanded");

      if (description.classList.contains("expanded")) {
        this.textContent = window.themeTranslations.readLess;
      } else {
        this.textContent = window.themeTranslations.readMore;
      }
    });

    // Set the initial button text based on locale
    button.textContent = window.themeTranslations.readMore;
  });
});
</script>