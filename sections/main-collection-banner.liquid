      "default": "text-start"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "default": "justify-center items-center",
      "options": [
        {
          "value": "justify-start items-start",
          "label": "Top left"
        },
        {
          "value": "justify-start items-center",
          "label": "Top center"
        },
        {
          "value": "justify-start items-end",
          "label": "Top right"
        },
        {
          "value": "justify-center items-start",
          "label": "Middle left"
        },
        {
          "value": "justify-center items-center",
          "label": "Middle center"
        },
        {
          "value": "justify-center items-end",
          "label": "Middle right"
        },
        {
          "value": "justify-end items-start",
          "label": "Bottom left"
        },
        {
          "value": "justify-end items-center",
          "label": "Bottom center"
        },
        {
          "value": "justify-end items-end",
          "label": "Bottom right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Collection image"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show collection image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "use_product_image",
      "label": "Use the first product image as the collection image",
