      "default": true
    },
    {
      "type": "select",
      "id": "collection_title_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h6",
          "label": "Extra extra small"
        },
        {
          "value": "h5",
          "label": "Extra small"
        },
        {
          "value": "h4",
          "label": "Small"
        },
        {
          "value": "h3",
          "label": "Medium"
        },
        {
          "value": "h2",
          "label": "Large"
        },
        {
          "value": "h1",
          "label": "Extra large"
        },
        {
          "value": "h0",
          "label": "Extra extra large"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "text_width",
      "label": "Text width",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
