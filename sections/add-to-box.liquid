<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
  $(document).ready(function() {
    $(".tab-menu li").click(function() {
      var tabId = $(this).find("a").attr("href");
      $(".tab-menu li").removeClass("active");
      $(this).addClass("active");
      $(".tab-content").removeClass("active");
      $(tabId).addClass("active");
      return false;
    });
  });
</script>

<script>
  function activateTab(hash) {
    // Deactivate all tabs and contents
    document.querySelectorAll('.tab-menu li').forEach(li => li.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(div => div.classList.remove('active'));

    // Activate the tab and corresponding content
    const activeTab = document.querySelector('.tab-menu a[href="' + hash + '"]');
    if (activeTab) {
      activeTab.parentElement.classList.add('active');
      document.querySelector(hash).classList.add('active');
    }
  }

  function updatePaginationLinks(hash) {
    // Update all pagination links to include the current hash
    document.querySelectorAll('.pagination a').forEach(link => {
      let href = link.getAttribute('href');
      href = href.split('#')[0]; // Remove existing hash
      href += hash; // Add the new hash
      link.setAttribute('href', href);
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    // Activate tab and update pagination links based on URL hash
    if (window.location.hash) {
      activateTab(window.location.hash);
      updatePaginationLinks(window.location.hash);
    }

    // Event listener for tab clicks
    document.querySelectorAll('.tab-menu a').forEach(tab => {
      tab.addEventListener('click', function(event) {
        event.preventDefault();
        let currentHash = this.getAttribute('href');
        activateTab(currentHash);
        updatePaginationLinks(currentHash);

        // Navigate to the first page of the selected tab
        window.location.href = window.location.pathname + '?page=1' + currentHash;
      });
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
      // Find the button by its class name
      var toggleButton = document.querySelector('.disclosure__toggleee');

      // Initially hide .disclosure-list elements
      var disclosureLists = document.querySelectorAll('.disclosure-listtt');
      disclosureLists.forEach(function(list) {
          list.style.visibility = 'hidden'; // Ensure visibility is hidden on load
          list.style.opacity = '0'; // Ensure opacity is 0 on load
      });

      // Add click event listener to the button
      toggleButton.addEventListener('click', function(event) {
          // Prevent the document click listener from firing
          event.stopPropagation();

          // Toggle visibility and opacity of .disclosure-list elements
          disclosureLists.forEach(function(list) {
              var isVisible = list.style.visibility === 'visible';
              list.style.visibility = isVisible ? 'hidden' : 'visible'; // Toggle visibility
              list.style.opacity = isVisible ? '0' : '1'; // Toggle opacity

          });
      });

      // Add click event listener to the document
      document.addEventListener('click', function() {
          // Hide .disclosure-list elements when clicking anywhere else
          disclosureLists.forEach(function(list) {
              list.style.visibility = 'hidden'; // Revert visibility
              list.style.opacity = '0'; // Revert opacity
          });
      });
  });
</script>

<style>
  .tab-menu {
    display: flex;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* Internet Explorer 10+ */
  }

  .tab-menu::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }

  .tab-menu li {
    flex: 0 0 auto; /* Prevent items from stretching */
    margin-right: 10px;
  }

  .tab-menu a {
    display: block;
    padding: 10px 15px;
    background: #ddd;
    border-radius: 5px;
    text-decoration: none;
    white-space: nowrap; /* Prevent text from breaking into multiple lines */
    user-select: none; /* Prevent text selection on drag */
  }
</style>

<script>
  const tabMenu = document.querySelector('.tab-menu');
  let isDown = false;
  let startX;
  let scrollLeft;

  tabMenu.addEventListener('mousedown', (e) => {
    isDown = true;
    tabMenu.classList.add('active');
    startX = e.pageX - tabMenu.offsetLeft;
    scrollLeft = tabMenu.scrollLeft;
  });
  tabMenu.addEventListener('mouseleave', () => {
    isDown = false;
    tabMenu.classList.remove('active');
  });
  tabMenu.addEventListener('mouseup', () => {
    isDown = false;
    tabMenu.classList.remove('active');
  });
  tabMenu.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - tabMenu.offsetLeft;
    const walk = (x - startX) * 2; // Scroll speed
    tabMenu.scrollLeft = scrollLeft - walk;
  });

  tabMenu.addEventListener('touchstart', (e) => {
    isDown = true;
    startX = e.touches[0].pageX - tabMenu.offsetLeft;
    scrollLeft = tabMenu.scrollLeft;
  });
  tabMenu.addEventListener('touchend', () => {
    isDown = false;
  });
  tabMenu.addEventListener('touchmove', (e) => {
    if (!isDown) return;
    const x = e.touches[0].pageX - tabMenu.offsetLeft;
    const walk = (x - startX) * 2; // Scroll speed
    tabMenu.scrollLeft = scrollLeft - walk;
  });
</script>
