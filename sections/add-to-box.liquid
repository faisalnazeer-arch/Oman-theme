{%- liquid
  assign collection_tab1 = collections[section.settings.collection_tab1]
  assign collection_tab2 = collections[section.settings.collection_tab2]
  assign collection_tab3 = collections[section.settings.collection_tab3]
  assign collection_tab4 = collections[section.settings.collection_tab4]
  assign collection_tab5 = collections[section.settings.collection_tab5]
-%}

{%- liquid
  if section.settings.enable_carousel
    assign product_limit = 20
  else
    assign product_limit = 200
  endif
  assign collection = collections[section.settings.collection]
-%}

<div class="section-id-{{ section.id }}">
  <div
    class="container{% if section.settings.enable_carousel %} container--not-mobile{% endif %}{% if section.settings.full_width %} container--no-max{% endif %}"
    {% if section.settings['section-id'] != noneid %}
      id="{{section.settings.section-id}}"
    {% endif %}
  >
    <div>
      <h2 class="hometitle h4-style align-center has-paging">
        {% if section.settings.enable_carousel -%}
          <a class="prev ltr-icon" href="#">{% render 'svg-chevron-left' %}</a>
        {%- endif %}
        <a class="has-paging__title" href="javascript:void(0);"
          ><span>{{ section.settings.title | escape }}</span></a
        >
        {% if section.settings.enable_carousel -%}
          <a class="next ltr-icon" href="#">{% render 'svg-chevron-right' %}</a>
        {%- endif %}
      </h2>

      <div class="collection-listing">
        <div class="product-list product-list--per-row-{{ section.settings.grid }} product-list--per-row-mob-{{ settings.prod_thumb_mob_per_row }} product-list--image-shape-{{ settings.prod_thumb_shape }} {% if section.settings.enable_carousel %}carousel{% endif %}">
          {% if section.settings.collection == blank %}
            {% for i in (1..product_limit) %}
            {% endfor %}
          {% else %}
            {%- liquid
              if settings.prod_thumb_shape == 'portrait-23'
                assign chosen_aspect_ratio = 0.67
              elsif settings.prod_thumb_shape == 'portrait-45'
                assign chosen_aspect_ratio = 0.8
              elsif settings.prod_thumb_shape == 'square'
                assign chosen_aspect_ratio = 1.0
              elsif settings.prod_thumb_shape == 'landscape-54'
                assign chosen_aspect_ratio = 1.25
              elsif settings.prod_thumb_shape == 'landscape-32'
                assign chosen_aspect_ratio = 1.50
              elsif settings.prod_thumb_shape == 'tallest'
                assign chosen_aspect_ratio = 99
                for product in collection.products limit: product_limit
                  if product.featured_media.preview_image.aspect_ratio < chosen_aspect_ratio
                    assign chosen_aspect_ratio = product.featured_media.preview_image.aspect_ratio
                  endif
                endfor
              else
                assign chosen_aspect_ratio = 0
                for product in collection.products limit: product_limit
                  if product.featured_media.preview_image.aspect_ratio > chosen_aspect_ratio
                    assign chosen_aspect_ratio = product.featured_media.preview_image.aspect_ratio
                  endif
                endfor
              endif
            -%}

            <div class="product-tabs">
              <div class="l-select">
                {%- assign input_prefix = 'annbarMobileNavvv' -%}

                {%- assign form_id = 'localization_form_' | append: input_prefix -%}
                {%- form 'localization', id: form_id, class: 'selectors-form' -%}
                  <div class="selectors-form__itemmm">
                    <div class="visually-hidden" id="lang-heading-{{ input_prefix }}">Language</div>

                    <div class="disclosureee" data-disclosure-locale>
                      <button
                        type="button"
                        class="disclosure__toggleee"
                        aria-expanded="false"
                        aria-controls="lang-list-{{ input_prefix }}"
                        aria-describedby="lang-heading-{{ input_prefix }}"
                        data-disclosure-toggle
                      >
                        {%- liquid
                          assign split_endonym = localization.language.endonym_name | split: ' '
                          for str in split_endonym
                            if forloop.first
                              assign capitalized_endonym = str | capitalize
                            else
                              assign capitalized_endonym = capitalized_endonym | append: ' ' | append: str
                            endif
                          endfor
                          echo capitalized_endonym
                        -%}
                        <span class="disclosure__toggle-arrow" role="presentation">
                          {%- render 'svg-chevron-down' -%}
                        </span>
                      </button>
                      <ul id="lang-list-{{ input_prefix }}" class="disclosure-listtt" data-disclosure-list>
                        {% for language in localization.available_languages %}
                          <li class="disclosure-list__item{% if language.iso_code == localization.language.iso_code %} disclosure-list__item--current{% endif %}">
                            <a
                              class="disclosure-list__option"
                              {% if language.iso_code == 'ar' %}
                                href="https://mls.om/ar/pages/build-your-box"
                              {% elsif language.iso_code == 'en' %}
                                href="https://mls.om/pages/build-your-box"
                              {% endif %}
                              data-value="{{ language.iso_code }}"
                              data-disclosure-option
                            >
                              {%- liquid
                                assign split_endonym = language.endonym_name | split: ' '
                                for str in split_endonym
                                  if forloop.first
                                    assign capitalized_endonym = str | capitalize
                                  else
                                    assign capitalized_endonym = capitalized_endonym | append: ' ' | append: str
                                  endif
                                endfor
                                echo capitalized_endonym
                              -%}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                      <input
                        type="hidden"
                        name="locale_code"
                        value="{{ localization.language.iso_code }}"
                        data-disclosure-input
                      >
                    </div>
                  </div>
                {%- endform -%}
              </div>

              <ul class="tab-menu">
                <li>
                  <a href="#tab1">{{ 'subscribe-widget.box-tab1' | t }}</a>
                </li>
                <li>
                  <a href="#tab2">{{ 'subscribe-widget.box-tab2' | t }}</a>
                </li>
                <li>
                  <a href="#tab3">{{ 'subscribe-widget.box-tab3' | t }}</a>
                </li>
                <li>
                  <a href="#tab4">{{ 'subscribe-widget.box-tab4' | t }}</a>
                </li>
                <li>
                  <a href="#tab5">{{ 'subscribe-widget.box-tab5' | t }}</a>
                </li>
              </ul>
              <div id="tab1" class="tab-content active  ">
                {% paginate collection_tab1.products by 50 %}
                  {% for product in collection_tab1.products %}
                    {% render 'add-to-box-product-block',
                      product: product,
                      collection: collection,
                      manual_image_load: section.settings.enable_carousel,
                      custom_aspect_ratio: chosen_aspect_ratio,
                      no_swiping: section.settings.enable_carousel,
                      no_quick_buy_markup: section.settings.enable_carousel
                    %}
                  {% endfor %}
                  {% render 'pagination', paginate: paginate %}
                {%- endpaginate -%}
              </div>

              <div id="tab2" class="tab-content">
                <!-- {% paginate collection_tab2.products by 50 %} -->
                {% for product in collection_tab2.products %}
                  {% render 'add-to-box-product-block',
                    product: product,
                    collection: collection,
                    manual_image_load: section.settings.enable_carousel,
                    custom_aspect_ratio: chosen_aspect_ratio,
                    no_swiping: section.settings.enable_carousel,
                    no_quick_buy_markup: section.settings.enable_carousel
                  %}
                {% endfor %}
                <!--
                  {% render 'pagination', paginate: paginate %}
                  {%- endpaginate -%}
                -->
              </div>

              <div id="tab3" class="tab-content">
                <!-- {% paginate collection_tab3.products by 50 %} -->
                {% for product in collection_tab3.products %}
                  {% render 'add-to-box-product-block',
                    product: product,
                    collection: collection,
                    manual_image_load: section.settings.enable_carousel,
                    custom_aspect_ratio: chosen_aspect_ratio,
                    no_swiping: section.settings.enable_carousel,
                    no_quick_buy_markup: section.settings.enable_carousel
                  %}
                {% endfor %}
                <!--
                  {% render 'pagination', paginate: paginate %}
                  {%- endpaginate -%}
                -->
              </div>

              <div id="tab4" class="tab-content">
                <!-- {% paginate collection_tab4.products by 50 %} -->
                {% for product in collection_tab4.products %}
                  {% render 'add-to-box-product-block',
                    product: product,
                    collection: collection,
                    manual_image_load: section.settings.enable_carousel,
                    custom_aspect_ratio: chosen_aspect_ratio,
                    no_swiping: section.settings.enable_carousel,
                    no_quick_buy_markup: section.settings.enable_carousel
                  %}
                {% endfor %}
                <!--
                  {% render 'pagination', paginate: paginate %}
                  {%- endpaginate -%}
                -->
              </div>

              <div id="tab5" class="tab-content">
                <!-- {% paginate collection_tab5.products by 50 %} -->
                {% for product in collection_tab5.products %}
                  {% render 'add-to-box-product-block',
                    product: product,
                    collection: collection,
                    manual_image_load: section.settings.enable_carousel,
                    custom_aspect_ratio: chosen_aspect_ratio,
                    no_swiping: section.settings.enable_carousel,
                    no_quick_buy_markup: section.settings.enable_carousel
                  %}
                {% endfor %}
                <!--
                  {% render 'pagination', paginate: paginate %}
                  {%- endpaginate -%}
                -->
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
