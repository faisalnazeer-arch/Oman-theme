<script>
   document.addEventListener('DOMContentLoaded', () => {
      const carousels = document.querySelectorAll('.custom-carousel');

      carousels.forEach(carousel => {
          let isDown = false;
          let startX;
          let scrollLeft;

          // Mouse event listeners
          carousel.addEventListener('mousedown', (e) => {
              isDown = true;
              carousel.classList.add('active');
              startX = e.pageX - carousel.offsetLeft;
              scrollLeft = carousel.scrollLeft;
          });

          carousel.addEventListener('mouseleave', () => {
              isDown = false;
              carousel.classList.remove('active');
          });

          carousel.addEventListener('mouseup', () => {
              isDown = false;
              carousel.classList.remove('active');
          });

          carousel.addEventListener('mousemove', (e) => {
              if (!isDown) return;
              e.preventDefault();
              const x = e.pageX - carousel.offsetLeft;
              const walk = (x - startX) * 2; // Adjust scroll speed here if needed
              carousel.scrollLeft = scrollLeft - walk;
          });

          // Touch event listeners
          carousel.addEventListener('touchstart', (e) => {
              isDown = true;
              startX = e.touches[0].pageX - carousel.offsetLeft;
              scrollLeft = carousel.scrollLeft;
          });

          carousel.addEventListener('touchend', () => {
              isDown = false;
          });

          carousel.addEventListener('touchmove', (e) => {
              if (!isDown) return;
              const x = e.touches[0].pageX - carousel.offsetLeft;
              const walk = (x - startX) * 1; // Adjust scroll speed here if needed
              carousel.scrollLeft = scrollLeft - walk;
          });
      });

      // Automatically show the first carousel and hide the second one by default
      (function initializeCarousel() {
          document.getElementById('carousel1').style.display = 'block';
          document.getElementById('carousel2').style.display = 'none';
          document.querySelector('.tab-button:nth-child(1)').classList.add('active');
          document.querySelector('.tab-button:nth-child(2)').classList.remove('active');
      })();
  });

  function showCarousel(carouselId) {
      if (carouselId === 1) {
          document.getElementById('carousel1').style.display = 'block';
          document.getElementById('carousel2').style.display = 'none';
      } else {
          document.getElementById('carousel1').style.display = 'none';
          document.getElementById('carousel2').style.display = 'block';
      }

      document.querySelectorAll('.tab-button').forEach((button, index) => {
          button.classList.toggle('active', index === carouselId - 1);
      });
  }
</script>
<script>
function scrollCarousel(carouselId, direction) {
    const carousel = document.querySelector(`#${carouselId} .custom-carousel`);
    const scrollAmount = carousel.clientWidth * 1; // Adjust this value for how far the scroll should move

    if (direction === 'left') {
        carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    } else {
        carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    }
}
</script>
