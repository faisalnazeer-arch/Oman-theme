    <div class="custom-carousel-container" id="carousel1">
      <div class="carousel-arrow left-arrow" onclick="scrollCarousel('carousel1', 'left')">&#10094;</div>
      <div class="custom-carousel-wrapper">
        <div class="custom-carousel">
          {% for block in section.blocks %}
            {% if block.type == 'beef' %}
              <div class="custom-carousel-item" onclick="location.href='{{ block.settings.link }}';">
                <div class="custom-image-container">
                  <img
                    data-class="LazyLoad"
                    src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII="
                    data-src="{{ block.settings.image | img_url: '300x300' }}"
                    alt="{{ block.settings.text }}"
                  >
                </div>
                <p>{{ block.settings.text }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="carousel-arrow right-arrow" onclick="scrollCarousel('carousel1', 'right')">&#10095;</div>
    </div>

    <div class="custom-carousel-container" id="carousel2" style="display:none;">
      <div class="carousel-arrow left-arrow" onclick="scrollCarousel('carousel2', 'left')">&#10094;</div>
      <div class="custom-carousel-wrapper">
        <div class="custom-carousel">
          {% for block in section.blocks %}
            {% if block.type == 'lamb' %}
              <div class="custom-carousel-item" onclick="location.href='{{ block.settings.link }}';">
                <div class="custom-image-container">
                  <img
                    data-class="LazyLoad"
                    src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII="
                    data-src="{{ block.settings.image | img_url: '300x300' }}"
                    alt="{{ block.settings.text }}"
                  >
                </div>
                <p>{{ block.settings.text }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="carousel-arrow right-arrow" onclick="scrollCarousel('carousel2', 'right')">&#10095;</div>
    </div>
