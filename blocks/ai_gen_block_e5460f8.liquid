{% doc %}
  @prompt
    "Create a Product Collection Grid section with a 3-column layout for desktop and a 1-column layout for mobile.
    
    Section Styling:
    
    Main Heading: Centered at the top: 'MLS EID AL ADHA COLLECTION' in bold, black, sans-serif font.
    
    Background: The section background should be white, but each collection card should have a light beige/cream background.
    
    Collection Card Design:
    
    Image Area: Each card must have an upload option for a product image. Behind the product image, include a diagonal orange/rust-colored pattern (mandala or geometric style) covering the bottom-right half of the image area.
    
    Decorative Elements: Include two hanging Arabic lantern (Fanous) icons at the top corners of each card.
    
    Text & CTA:
    
    Below the image, add the collection title in bold black text (e.g., 'Eid-al-Adha Steak').
    
    Below the title, a solid maroon button (#A30000) with white text 'VIEW COLLECTION'. The button should have slightly rounded corners.
    
    Functionality: > * Each card must be linkable to a specific Shopify collection.
    
    Ensure the grid has clean spacing (gutters) between cards.", Decorative elements enable option add, Button enable option add, title enable option add, remove collection title also remove card bg color , collection image size add e.g adapt to image full image, auto, square , "Create a Custom Image Grid section.
    
    Layout Requirements:
    
    Grid: 3 columns for desktop and 1 column for mobile.
    
    Functionality: Each image must have a clickable link option to connect it to a specific Shopify collection.
    
    Assets: Provide a placeholder for me to upload my own images (since my images already contain the title and button design).
    
    Styling:
    
    Background: Pure white background for the entire section.
    
    Spacing: Add clean, equal gaps (15px to 20px) between the images.
    
    Padding: Ensure there is enough padding at the top and bottom of the section so it doesn't look cramped.
    
    Alignment: Images should be perfectly centered." aspect ratio (size) option add
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-image-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #ffffff;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-custom-image-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-custom-image-grid__item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-custom-image-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-custom-image-grid__item-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-custom-image-grid__item-wrapper-{{ ai_gen_id }}--adapt {
    aspect-ratio: auto;
  }

  .ai-custom-image-grid__item-wrapper-{{ ai_gen_id }}--square {
    aspect-ratio: 1;
  }

  .ai-custom-image-grid__item-wrapper-{{ ai_gen_id }}--portrait {
    aspect-ratio: 0.75;
  }

  .ai-custom-image-grid__item-wrapper-{{ ai_gen_id }}--landscape {
    aspect-ratio: 1.5;
  }

  .ai-custom-image-grid__item-wrapper-{{ ai_gen_id }}--wide {
    aspect-ratio: 2;
  }

  .ai-custom-image-grid__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ai-custom-image-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ai-custom-image-grid__image-{{ ai_gen_id }}--contain {
    object-fit: contain;
  }

  .ai-custom-image-grid__image-{{ ai_gen_id }}--cover {
    object-fit: cover;
  }

  .ai-custom-image-grid__image-{{ ai_gen_id }}--adapt {
    object-fit: contain;
    width: 100%;
    height: auto;
  }

  .ai-custom-image-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-custom-image-grid__placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-custom-image-grid__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 13px;
    color: #666;
    text-align: center;
    pointer-events: none;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
  }

  @media screen and (max-width: 989px) {
    .ai-custom-image-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-custom-image-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-custom-image-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.75 }}px 16px {{ block.settings.section_padding_bottom | times: 0.75 }}px;
    }
  }
{% endstyle %}

<custom-image-grid-{{ ai_gen_id }} class="ai-custom-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-custom-image-grid__container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign link_key = 'link_' | append: i
        
        assign image = block.settings[image_key]
        assign link = block.settings[link_key]
      %}

      <div class="ai-custom-image-grid__item-{{ ai_gen_id }}">
        <div class="ai-custom-image-grid__item-wrapper-{{ ai_gen_id }} ai-custom-image-grid__item-wrapper-{{ ai_gen_id }}--{{ block.settings.image_ratio }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-custom-image-grid__link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-custom-image-grid__link-{{ ai_gen_id }}">
          {% endif %}

            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="800"
                height="800"
                class="ai-custom-image-grid__image-{{ ai_gen_id }} ai-custom-image-grid__image-{{ ai_gen_id }}--{{ block.settings.image_fit }}"
              >
            {% else %}
              <div class="ai-custom-image-grid__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-custom-image-grid__empty-state-{{ ai_gen_id }}">
                  Upload image {{ i }}
                </div>
              </div>
            {% endif %}

          {% if link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</custom-image-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomImageGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeGrid();
      }

      initializeGrid() {
        const items = this.querySelectorAll('.ai-custom-image-grid__item-{{ ai_gen_id }}');
        
        items.forEach((item, index) => {
          item.style.animationDelay = `${index * 0.1}s`;
        });
      }
    }

    customElements.define('custom-image-grid-{{ ai_gen_id }}', CustomImageGrid{{ ai_gen_id }});
  })();
</script>

