{% doc %}
  @prompt
    "Create a call-to-action (CTA) button section. The button should have a deep maroon background (#A30000) with white text that reads 'VIEW EID AL ADHA COLLECTION' in all caps.
    
    Button Styling:
    
    Font: Bold, clean sans-serif (like Montserrat or Inter).
    
    Shape: Rounded corners (border-radius should be around 12px to 15px).
    
    Padding: Generous horizontal padding to make the button look wide and professional.
    
    Alignment: Perfectly centered on the page with white space above and below.
    
    Hover Effect: Add a subtle darken effect or a slight scale-up when the mouse hovers over it.", Button style
    mobile customize too add all option of desktop on mobile, Hover effect options add with none
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cta-button-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
    text-align: center;
  }

  .ai-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.font_size }}px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-cta-button-{{ ai_gen_id }}:hover {
    {% if block.settings.hover_effect == 'darken' %}
      background-color: {{ block.settings.button_hover_color }};
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(163, 0, 0, 0.3);
    {% elsif block.settings.hover_effect == 'scale' %}
      transform: scale(1.05);
      box-shadow: 0 4px 12px rgba(163, 0, 0, 0.3);
    {% elsif block.settings.hover_effect == 'both' %}
      background-color: {{ block.settings.button_hover_color }};
      transform: scale(1.05) translateY(-2px);
      box-shadow: 0 6px 16px rgba(163, 0, 0, 0.4);
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-cta-button-container-{{ ai_gen_id }} {
      padding: {{ block.settings.spacing_top_mobile }}px 0 {{ block.settings.spacing_bottom_mobile }}px;
    }

    .ai-cta-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
      padding: {{ block.settings.padding_vertical_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
      border-radius: {{ block.settings.border_radius_mobile }}px;
      width: {{ block.settings.mobile_width_percent }}%;
    }
  }
{% endstyle %}

<ai-cta-button-{{ ai_gen_id }} class="ai-cta-button-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <a href="{{ block.settings.button_link }}" class="ai-cta-button-{{ ai_gen_id }}">
    {{ block.settings.button_text }}
  </a>
</ai-cta-button-{{ ai_gen_id }}>

<script>
  (function() {
    class AiCtaButton{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const button = this.querySelector('.ai-cta-button-{{ ai_gen_id }}');
        
        button.addEventListener('click', function(e) {
          if (!button.getAttribute('href') || button.getAttribute('href') === '#') {
            e.preventDefault();
          }
        });
      }
    }

    customElements.define('ai-cta-button-{{ ai_gen_id }}', AiCtaButton{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "CTA button",
  "settings": [
    {
      "type": "header",
      "content": "Button content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "VIEW EID AL ADHA COLLECTION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Desktop style"
    },
    {
      "type": "font_picker",
      "id": "button_font",
      "label": "Font",
      "default": "helvetica_n7"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#A30000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#8B0000"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Hover effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "darken",
          "label": "Darken"
        },
        {
          "value": "scale",
          "label": "Scale up"
        },
        {
          "value": "both",
          "label": "Darken and scale"
        }
      ],
      "default": "both"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile style"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "border_radius_mobile",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Horizontal padding",
      "min": 15,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_vertical_mobile",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_width_percent",
      "label": "Mobile width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "spacing_top_mobile",
      "label": "Top spacing",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "spacing_bottom_mobile",
      "label": "Bottom spacing",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "CTA button"
    }
  ]
}
{% endschema %}