{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.container_background_color }};
    padding-top: {{ block.settings.container_padding_top }}px;
    padding-bottom: {{ block.settings.container_padding_bottom }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-marquee-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
    background-color: {{ block.settings.scrollbar_background_color }};
    padding-top: {{ block.settings.scrollbar_padding_top }}px;
    padding-bottom: {{ block.settings.scrollbar_padding_bottom }}px;
    padding-left: {{ block.settings.scrollbar_padding_horizontal }}px;
    padding-right: {{ block.settings.scrollbar_padding_horizontal }}px;
    border-radius: {{ block.settings.scrollbar_border_radius }}px;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  {% if block.settings.pause_on_hover %}
    .ai-marquee-track-{{ ai_gen_id }}:hover {
      animation-play-state: paused;
    }
  {% endif %}

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding-right: 40px;
  }

  .ai-marquee-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-size: {{ block.settings.font_size }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }

  .ai-marquee-separator-{{ ai_gen_id }} {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: {{ block.settings.text_color }};
    border-radius: 50%;
    margin: 0 20px;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<ai-marquee-{{ ai_gen_id }} class="ai-marquee-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-track-{{ ai_gen_id }}">
      <div class="ai-marquee-content-{{ ai_gen_id }}">
        <p class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.marquee_text_1 }}</p>
        <span class="ai-marquee-separator-{{ ai_gen_id }}"></span>
        <p class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.marquee_text_2 }}</p>
        <span class="ai-marquee-separator-{{ ai_gen_id }}"></span>
        <p class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.marquee_text_3 }}</p>
      </div>
      <div class="ai-marquee-content-{{ ai_gen_id }}">
        <p class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.marquee_text_1 }}</p>
        <span class="ai-marquee-separator-{{ ai_gen_id }}"></span>
        <p class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.marquee_text_2 }}</p>
        <span class="ai-marquee-separator-{{ ai_gen_id }}"></span>
        <p class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.marquee_text_3 }}</p>
      </div>
    </div>
  </div>
</ai-marquee-{{ ai_gen_id }}>

<script>
  (function() {
    class AiMarquee{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-marquee-track-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-marquee-content-{{ ai_gen_id }}');
        
        if (this.track && this.content) {
          this.duplicateContent();
        }
      }

      duplicateContent() {
        const contentWidth = this.content.offsetWidth;
        const containerWidth = this.offsetWidth;
        const duplicatesNeeded = Math.ceil(containerWidth / contentWidth) + 2;
        
        for (let i = 0; i < duplicatesNeeded; i++) {
          const clone = this.content.cloneNode(true);
          this.track.appendChild(clone);
        }
      }
    }

    customElements.define('ai-marquee-{{ ai_gen_id }}', AiMarquee{{ ai_gen_id }});
  })();
</script>

