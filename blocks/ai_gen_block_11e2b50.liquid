{% doc %}
  @prompt
    Create a custom section with two layouts:
        Mobile View:
        
        First: Store information (title, subtitle, address, opening hours)
        Second: Store photo (full width)
        Third: Google Map (full width)
        
        Desktop View:
        
        Side-by-side layout: Left side = Store information + photo, Right side = Google Map
        
        Section Title: MLS Gourmet Butchery
        Content:
        
        Main Title: MLS Gourmet Butchery - Abu Dhabi
        Subtitle: Meat Market, Mushrif Mall, Abu Dhabi
        Hours: Everyday: 10am - 10pm
        Image: Use the butcher shop interior photo with 4 staff members behind the meat counter
        Map: Show Google Map centered on Mushrif Mall, Abu Dhabi
        
        Style: Clean, modern, professional, with blue accents matching the screenshot. Make it responsive., three columns in desktop in a row first info then image and then map
        
        mobile is good to go, also needed button of get diredctions with direction icon below the timings on store, map should be in dark mode
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-store-location-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-store-location-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-store-location-title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.section_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 40px;
  }

  .ai-store-location-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 750px) {
    .ai-store-location-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 32px;
    }
  }

  .ai-store-location-info-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    padding: 32px;
    border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-store-location-info-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    font-weight: 700;
  }

  .ai-store-location-info-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.accent_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-store-location-info-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-store-location-info-label-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.label_color }};
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-store-location-info-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-store-location-directions-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
    width: fit-content;
  }

  .ai-store-location-directions-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-store-location-directions-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  .ai-store-location-image-{{ ai_gen_id }} {
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    height: 100%;
    min-height: 300px;
  }

  .ai-store-location-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-store-location-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }

  .ai-store-location-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-store-location-map-{{ ai_gen_id }} {
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    height: 100%;
    min-height: 300px;
  }

  .ai-store-location-map-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    border: 0;
    min-height: 300px;
  }

  @media (min-width: 750px) {
    .ai-store-location-image-{{ ai_gen_id }},
    .ai-store-location-map-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-store-location-image-placeholder-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-store-location-map-{{ ai_gen_id }} iframe {
      min-height: 400px;
    }
  }
{% endstyle %}

<store-location-{{ ai_gen_id }}
  class="ai-store-location-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-store-location-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="ai-store-location-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    <div class="ai-store-location-grid-{{ ai_gen_id }}">
      <div class="ai-store-location-info-{{ ai_gen_id }}">
        {% if block.settings.store_title != blank %}
          <h3 class="ai-store-location-info-title-{{ ai_gen_id }}">{{ block.settings.store_title }}</h3>
        {% endif %}

        {% if block.settings.store_subtitle != blank %}
          <p class="ai-store-location-info-subtitle-{{ ai_gen_id }}">{{ block.settings.store_subtitle }}</p>
        {% endif %}

        {% if block.settings.store_address != blank %}
          <div class="ai-store-location-info-section-{{ ai_gen_id }}">
            <div class="ai-store-location-info-label-{{ ai_gen_id }}">Address</div>
            <div class="ai-store-location-info-text-{{ ai_gen_id }}">{{ block.settings.store_address }}</div>
          </div>
        {% endif %}

        {% if block.settings.store_hours != blank %}
          <div class="ai-store-location-info-section-{{ ai_gen_id }}">
            <div class="ai-store-location-info-label-{{ ai_gen_id }}">Hours</div>
            <div class="ai-store-location-info-text-{{ ai_gen_id }}">{{ block.settings.store_hours }}</div>
          </div>
        {% endif %}

        {% if block.settings.directions_url != blank %}
          <a
            href="{{ block.settings.directions_url }}"
            class="ai-store-location-directions-btn-{{ ai_gen_id }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              class="ai-store-location-directions-icon-{{ ai_gen_id }}"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polygon points="3 11 22 2 13 21 11 13 3 11"></polygon>
            </svg>
            Get Directions
          </a>
        {% endif %}
      </div>

      <div class="ai-store-location-image-{{ ai_gen_id }}">
        {% if block.settings.store_image %}
          <img
            src="{{ block.settings.store_image | image_url: width: 800 }}"
            alt="{{ block.settings.store_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.store_image.width }}"
            height="{{ block.settings.store_image.height }}"
          >
        {% else %}
          <div class="ai-store-location-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-store-location-map-{{ ai_gen_id }}">
        {% if block.settings.map_embed_url != blank %}
          <iframe
            src="{{ block.settings.map_embed_url }}"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        {% else %}
          <div class="ai-store-location-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</store-location-{{ ai_gen_id }}>

<script>
  (function() {
    class StoreLocation{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('store-location-{{ ai_gen_id }}', StoreLocation{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Store location",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "MLS Gourmet Butchery"
    },
    {
      "type": "range",
      "id": "section_title_size",
      "label": "Section title size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "Store information"
    },
    {
      "type": "text",
      "id": "store_title",
      "label": "Store title",
      "default": "MLS Gourmet Butchery - Abu Dhabi"
    },
    {
      "type": "text",
      "id": "store_subtitle",
      "label": "Store subtitle",
      "default": "Meat Market, Mushrif Mall, Abu Dhabi"
    },
    {
      "type": "textarea",
      "id": "store_address",
      "label": "Address",
      "default": "Mushrif Mall, Abu Dhabi, United Arab Emirates"
    },
    {
      "type": "textarea",
      "id": "store_hours",
      "label": "Opening hours",
      "default": "Everyday: 10am - 10pm"
    },
    {
      "type": "url",
