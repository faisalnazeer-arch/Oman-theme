{% doc %}
  @prompt
    "Create a Testimonial Slider Section with a high-quality background image of raw meat (T-bone steak). Apply a dark semi-transparent overlay over the image to ensure white text is clearly readable.
    
    Layout Requirements:
    
    Header: A fixed, non-scrolling bold heading at the top: 'MLS IS LOVED BY 50K+ CUSTOMERS' in white, all-caps, sans-serif font.
    
    Stars: Below the header, include a 5-star rating icon row with an option to upload custom star SVG/images.
    
    Testimonial Content: A slider area for reviews including:
    
    A bold review title (e.g., 'Perfect as usual').
    
    Review text in quotes (e.g., 'Fresh Tender Well packed').
    
    Customer name in bold and a 'Verified Customer' tag in smaller font.
    
    Controls: Include pagination dots at the bottom. Disable Autoplay; the slider should only move when the user interacts with it.
    
    Styling: Center-align all elements. Use a clean, modern aesthetic with white text and ample spacing.", review star and review content autoplay option add, Stars icon auplay add
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-slider-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-testimonial-slider__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-testimonial-slider__background-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-slider__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-slider__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-testimonial-slider__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 2;
  }

  .ai-testimonial-slider__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-testimonial-slider__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-testimonial-slider__heading-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 {{ block.settings.stars_spacing }}px 0;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
  }

  .ai-testimonial-slider__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    justify-content: center;
  }

  .ai-testimonial-slider__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-testimonial-slider__star-{{ ai_gen_id }}.animate {
    opacity: 1;
    transform: scale(1);
  }

  .ai-testimonial-slider__star-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-testimonial-slider__star-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.star_color }};
  }

  .ai-testimonial-slider__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-testimonial-slider__slide-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    color: #ffffff;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .ai-testimonial-slider__slide-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-testimonial-slider__review-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_title_size }}px;
    font-weight: 700;
    margin: 0 0 {{ block.settings.review_spacing }}px 0;
    color: #ffffff;
  }

  .ai-testimonial-slider__review-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.customer_spacing }}px 0;
    color: #ffffff;
  }

  .ai-testimonial-slider__customer-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .ai-testimonial-slider__customer-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.customer_name_size }}px;
    font-weight: 700;
    color: #ffffff;
  }

  .ai-testimonial-slider__verified-{{ ai_gen_id }} {
    font-size: {{ block.settings.verified_text_size }}px;
    color: rgba(255, 255, 255, 0.8);
  }

  .ai-testimonial-slider__pagination-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: {{ block.settings.pagination_spacing }}px;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
    padding: 0;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }}.active {
    background-color: #ffffff;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 0.7);
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-testimonial-slider__review-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.review_title_size | times: 0.8 }}px;
    }

    .ai-testimonial-slider__review-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.review_text_size | times: 0.9 }}px;
    }

    .ai-testimonial-slider__content-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px;
    }
  }
{% endstyle %}

<testimonial-slider-{{ ai_gen_id }}
  class="ai-testimonial-slider-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.enable_autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  data-star-animation="{{ block.settings.enable_star_animation }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-slider__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-testimonial-slider__background-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-testimonial-slider__background-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-testimonial-slider__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-testimonial-slider__content-{{ ai_gen_id }}">
    <div class="ai-testimonial-slider__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-testimonial-slider__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      <div class="ai-testimonial-slider__stars-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          <div class="ai-testimonial-slider__star-{{ ai_gen_id }}" data-star-index="{{ forloop.index0 }}">
            {% if block.settings.star_image %}
              <img
                src="{{ block.settings.star_image | image_url: width: 100 }}"
                alt="Star"
                loading="lazy"
                width="100"
                height="100"
              >
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ai-testimonial-slider__slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign review_title_key = 'review_' | append: i | append: '_title'
          assign review_text_key = 'review_' | append: i | append: '_text'
          assign customer_name_key = 'review_' | append: i | append: '_customer_name'

          assign review_title = block.settings[review_title_key]
          assign review_text = block.settings[review_text_key]
          assign customer_name = block.settings[customer_name_key]
        %}

        {% if review_title != blank or review_text != blank or customer_name != blank %}
          <div
            class="ai-testimonial-slider__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide-index="{{ forloop.index0 }}"
          >
            {% if review_title != blank %}
              <h3 class="ai-testimonial-slider__review-title-{{ ai_gen_id }}">{{ review_title }}</h3>
            {% endif %}

            {% if review_text != blank %}
              <p class="ai-testimonial-slider__review-text-{{ ai_gen_id }}">"{{ review_text }}"</p>
            {% endif %}

            <div class="ai-testimonial-slider__customer-{{ ai_gen_id }}">
              {% if customer_name != blank %}
                <div class="ai-testimonial-slider__customer-name-{{ ai_gen_id }}">{{ customer_name }}</div>
              {% endif %}
              <div class="ai-testimonial-slider__verified-{{ ai_gen_id }}">{{ block.settings.verified_text }}</div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-testimonial-slider__pagination-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign review_title_key = 'review_' | append: i | append: '_title'
          assign review_text_key = 'review_' | append: i | append: '_text'
          assign customer_name_key = 'review_' | append: i | append: '_customer_name'

          assign review_title = block.settings[review_title_key]
          assign review_text = block.settings[review_text_key]
          assign customer_name = block.settings[customer_name_key]
        %}

        {% if review_title != blank or review_text != blank or customer_name != blank %}
          <button
            class="ai-testimonial-slider__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonial-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.stars = [];
        this.autoplayInterval = null;
        this.starAnimationInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-testimonial-slider__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-testimonial-slider__dot-{{ ai_gen_id }}'));
        this.stars = Array.from(this.querySelectorAll('.ai-testimonial-slider__star-{{ ai_gen_id }}'));
        
        this.autoplayEnabled = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;
        this.starAnimationEnabled = this.dataset.starAnimation === 'true';

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            this.resetAutoplay();
          });
        });

        if (this.starAnimationEnabled) {
          this.animateStars();
          this.starAnimationInterval = setInterval(() => {
            this.animateStars();
          }, 5000);
        } else {
          this.stars.forEach(star => star.classList.add('animate'));
        }

        if (this.autoplayEnabled && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
        if (this.starAnimationInterval) {
          clearInterval(this.starAnimationInterval);
        }
      }

      animateStars() {
        this.stars.forEach(star => star.classList.remove('animate'));
        
        this.stars.forEach((star, index) => {
          setTimeout(() => {
            star.classList.add('animate');
          }, index * 100);
        });
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        if (this.autoplayEnabled) {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        this.dots[this.currentSlide].classList.remove('active');

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        this.dots[this.currentSlide].classList.add('active');
      }
    }

    customElements.define('testimonial-slider-{{ ai_gen_id }}', TestimonialSlider{{ ai_gen_id }});
  })();
</script>

