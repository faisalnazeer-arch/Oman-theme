<script>
  // Helper function to normalize the text for comparison (lowercase and removing special characters)
  function normalizeText(text) {
    // Replace different apostrophe characters, lowercase, remove special characters, and replace multiple spaces with a single space
    return text.toLowerCase()
      .replace(/[^\w\s'-]/g, '')  // Allows apostrophes and dashes
      .replace(/\s+/g, ' ')       // Replace multiple spaces with a single space
      .trim();
  }

  // Fetch customer's IP and determine their location
  fetch('https://api.ipify.org?format=json')
    .then(response => response.json())
    .then(data => {
      const customerIp = data.ip;
      console.log("Customer IP Address: " + customerIp);

      const apiKey = "9a4148fc255e41a88995e99e0caa6701"; // Your API key for ipgeolocation.io
      const geoApiUrl = `https://api.ipgeolocation.io/ipgeo?apiKey=${apiKey}&ip=${customerIp}&fields=geo`;

      fetch(geoApiUrl)
        .then(response => response.json())
        .then(geoData => {
          console.log("Geolocation Data Country:", geoData.country_name);
          console.log("Geolocation Data:", geoData);

          // Check if the city is Lahore
          if (geoData.country_name  === "United Arab Emirates") {
            console.log("Customer is from Oman.");

            // Target product titles (normalized for comparison)
            const targetProductTitles = [
              
              normalizeText("Abu Dhabi - 10 steaks offer AUS Grass-Fed Beef Ribeye 250gm x 10"),
              normalizeText("Abu Dhabi - 10 steaks offer AUS Grass-Fed Beef Striploin 250gm x 10"),
              normalizeText("Abu Dhabi - 10kg AUS Grass-Fed Mutton Bone-in Cubes Box"),
              normalizeText("Abu Dhabi - 4 steaks offer AUS Angus Beef Tenderloin 250gm x 4"),
              normalizeText("Abu Dhabi - AUS Grass-Fed Mutton Mishkak Barbecue Cubes Offer 1kg"),
              normalizeText("Abu Dhabi - Freshly Slaughtered Australian Lamb Whole Carcass 18 Kg"),
              normalizeText("Abu Dhabi - MLS Beef 20 Burgers Box"),
              normalizeText("Abu Dhabi - Nadeem’s AED 500- 24 Steaks Box"),
              normalizeText("Abu Dhabi - 4 steaks offer AUS Wagyu Beef Striploin Steak MB 6/7 250gm x 4"),
              normalizeText("Abu Dhabi - NZ Grass-Fed Beef Mince Offer 1kg")
            ];
            console.log("Target Product Titles:", targetProductTitles);

            // Now, dynamically get the product title from the page
            const productTitleElement = document.querySelector('.product-title'); // This targets the <h1> element containing the product title
            if (productTitleElement) {
              const productTitle = productTitleElement.textContent.trim(); // Get the product title text
              console.log("Product Title on the page:", productTitle);

              // Normalize the product title for comparison
              const normalizedProductTitle = normalizeText(productTitle);
              console.log("Normalized Product Title:", normalizedProductTitle);

              // Check if the product matches any of the target product titles
              if (targetProductTitles.includes(normalizedProductTitle)) {
                console.log("Product found: ", productTitle);

                // Find the Add to Cart button dynamically (without relying on the form ID)
                const addToCartButton = document.querySelector('.product-info__add-button');
                console.log("Add to Cart Button:", addToCartButton);

                if (addToCartButton) {
                  console.log("Hiding Add to Cart Button...");
                  addToCartButton.style.display = 'none'; // Hide the Add to Cart button

                 const outOfStockMessage = document.createElement('p');
outOfStockMessage.textContent = 'Only for Abu Dhabi';

// Apply inline styles
outOfStockMessage.style.color = '#fff'; // Text color
outOfStockMessage.style.background = '#000'; // Background color
outOfStockMessage.style.paddingTop = '8px'; // Padding at the top
outOfStockMessage.style.paddingBottom = '8px'; // Padding at the bottom
outOfStockMessage.style.borderRadius = '10px'; // Rounded corners
outOfStockMessage.style.textAlign = 'center'; // Center-align the text

addToCartButton.parentElement.appendChild(outOfStockMessage); // Append the Out of Stock message near the Add to Cart button
                } else {
                  console.log("Add to Cart button not found!");
                }
              } else {
                console.log("No match found for product title:", productTitle);
              }
            } else {
