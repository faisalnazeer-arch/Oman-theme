            referBtn.style.display = 'none';
        } else {
            referBtn.style.display = '';
        }
    }
});

// Also check on drawer open/close
const observer = new MutationObserver(() => {
    const drawer = document.querySelector('quick-add-drawer');
    const referBtn = document.querySelector('.sca_aff_customer_refer_button');
    if (drawer && referBtn) {
        referBtn.style.display = drawer.hasAttribute('open') ? 'none' : '';
    }
});
observer.observe(document.body, { attributes: true, subtree: true });
</script>
