{%- liquid
  assign rtl = false
  assign rtl_iso_codes = 'ar,arc,dv,fa,ha,he,khw,ks,ku,ps,ur,yi' | split: ','
  assign current_code_first_part = localization.language.iso_code | split: '-' | first

  if rtl_iso_codes contains current_code_first_part
    assign rtl = true
  endif

  assign dock_cart_drawer = false
  if settings.dock_cart_drawer and settings.cart_type == 'drawer' and request.page_type != 'cart'
    assign dock_cart_drawer = true
  endif

  assign body_font_bold = settings.body_font | font_modify: 'weight', '500'
  assign body_font_italic = settings.body_font | font_modify: 'style', 'italic'
  assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'

  # constants
  assign breakpoint_sm = 600
  assign breakpoint_md = 769
  assign gutter_sm = 20
  assign gutter_md = 48
  assign gutter_lg = 64
-%}

<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{% if rtl %}rtl{% else %}ltr{% endif %}">




  <head>
    
{% render 'local-business-schema' %}
    
    <!-- SEOAnt Speed Up Script -->{%- if shop.metafields.seoantAppSiteSpeedUpV2.switch == 1 -%}{% include 'SEOAnt-SpeedUp' %}{%- endif -%}<!-- /SEOAnt Speed Up Script -->
    


    
  {%- liquid
  assign og_title = page_title | default: shop.name
  assign og_description = page_description | default: shop.description
  assign og_url = canonical_url | default: shop.url
  assign og_type = 'website'
  assign og_image = nil

  case request.page_type

    when 'index'
      assign og_title = shop.name
      assign og_description = shop.description
      assign og_image = settings.share_image

    when 'product'
      assign og_type = 'product'
      assign og_title = product.title
      assign og_description = product.description | strip_html | truncatewords: 30
      assign og_image = product.featured_image

    when 'collection'
      assign og_type = 'website'
      assign og_title = collection.title
      assign og_description = collection.description | strip_html | truncatewords: 30 | default: shop.description
      assign og_image = collection.image
      if og_image == blank and collection.products_count > 0
        assign og_image = collection.products.first.featured_image
      endif

    when 'article'
      assign og_type = 'article'
      assign og_title = article.title
      assign og_description = article.excerpt | strip_html | truncatewords: 30 | default: shop.description
      assign og_image = article.image

    when 'page'
      assign og_title = page.title
      assign og_image = page.image

  endcase

  if og_image == blank
    assign og_image = settings.share_image
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:url" content="{{ og_url }}">

{%- if og_image != blank -%}
  <meta property="og:image" content="{{ og_image | image_url: width: 1200, height: 630, crop: 'center' }}">
  <meta property="og:image:secure_url" content="{{ og_image | image_url: width: 1200, height: 630, crop: 'center' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/jpeg">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if og_image != blank -%}
<meta name="twitter:image" content="{{ og_image | image_url: width: 1200, height: 630, crop: 'center' }}">
{%- endif -%}

    
    
