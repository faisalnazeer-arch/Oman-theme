<script>
    (function () {

      const now = new Date();
      const currentHour = now.getHours(); // 0–23

      const isBetween5And8 = currentHour >= 17 && currentHour < 20;

      fetch("/cart/update.js", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          attributes: {
            between_5pm_8pm: isBetween5And8 ? "true" : "false"
          }
        })
      }).catch(function (e) {
        console.log("Time check attribute error:", e);
      });

    })();
  </script>
